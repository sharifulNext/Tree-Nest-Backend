{
  "version": 2,
  "builds": [
    {
      "src": "index.json",
      "use": "@vercel/node",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js",
        "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    }
  ]
}
